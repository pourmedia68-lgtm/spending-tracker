# Database
DATABASE_URL="postgresql://spending:spending@localhost:5432/spending_tracker?schema=public"

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins. Use "*" only for local dev.
CORS_ORIGINS="*"

# JWT
# Use a 32+ byte random string. Generate with `openssl rand -base64 48`.
JWT_ACCESS_SECRET="change-me-to-a-long-random-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"
JWT_REFRESH_TTL="30d"

# Google OAuth — get these at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match the redirect URI registered in Google Cloud Console.
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
# Where to redirect the user after a successful Google login (deep link
# back to the mobile app). Example: "spendingtracker://auth/callback".
OAUTH_SUCCESS_REDIRECT="http://localhost:3000/auth/google/success"
